# Xendit Configuration
# Dapatkan dari Xendit Dashboard -> Settings -> API Keys
XENDIT_SECRET_KEY=xnd_development_...
XENDIT_PUBLIC_KEY=xnd_public_development_...

# Token validasi webhook (Opsional tapi disarankan)
# Set di Xendit Dashboard -> Settings -> Webhooks -> Verification Token
XENDIT_WEBHOOK_TOKEN=your_webhook_verification_token

# Firebase Configuration (Service Account)
# Dapatkan dari Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
FIREBASE_PROJECT_ID=ayaay-724f7
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@ayaay-724f7.iam.gserviceaccount.com
# Gunakan tanda petik dan \n letakkan dalam satu baris untuk Netlify UI
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE... \n-----END PRIVATE KEY-----\n"

# Site URL (untuk redirect success/failure)
SITE_URL=http://localhost:8888
# Untuk production ubah SITE_URL=https://namadomainkamu.com
